# --- DATABASE ---
DATABASE_URL=postgres://osintuser:secure_password_here@localhost:5432/osintdb
# Test database URL used in integration tests
MIMIKRI_TEST_DB_URL=postgres://osintuser:secure_password_here@localhost:5432/osintdb_test

# --- SECURITY & COMPLIANCE ---
# Strict scope checks (prevent scans on out-of-scope targets)
STRICT_SCOPE=true
# Allow destructive probes (0/false = disabled, 1/true = enabled). MUST be set to 1/true along with target configurations for destructive plugins.
MIMIKRI_DESTRUCTIVE=0
# Approval gate timeout in seconds for interactive target review
MIMIKRI_APPROVAL_TIMEOUT=300

# --- OSINT / RECON SERVICES ---
CHAOS_API_KEY=
NETLAS_API_KEY=
SECURITYTRAILS_API_KEY=
SHODAN_API_KEY=
CRIMINALIP_API_KEY=
FOFA_EMAIL=
FOFA_KEY=
ZOOMEYE_KEY=
NETLAS_DAILY_BUDGET=33

# --- BUG BOUNTY PLATFORMS ---
H1_USERNAME=
H1_API_KEY=
BUGCROWD_API_KEY=
INTIGRITI_TOKEN=
BB_PROGRAM_HANDLE=

# --- INTEGRATION & ORCHESTRATION ---
